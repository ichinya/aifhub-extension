{
  "name": "aifhub-extension",
  "version": "0.11.0",
  "description": "Upstream-first extension for AI Factory: bootstrap remains extension-owned; `aif-plan`, `aif-implement`, `aif-verify`, and `aif-fix` connect through `injections`; `aif-done` remains the extension-owned finalizer; Codex and Claude runtime files publish through top-level `agentFiles`.",
  "compat": {
    "ai-factory": ">=2.10.0 <3.0.0"
  },
  "sources": {
    "ai-factory": {
      "url": "https://github.com/lee-to/ai-factory",
      "version": "2.10.0",
      "baselineVersion": "2.0.0",
      "lastSync": "2026-04-20",
      "notes": "Проверено против upstream 2.10.0; именно там документированы и провалидированы runtime-aware agentFiles и extension-defined runtime metadata, поэтому compat.ai-factory теперь начинается с 2.10.0"
    },
    "openspec": {
      "url": "https://github.com/Fission-AI/OpenSpec",
      "version": "1.3.1",
      "supportedRange": ">=1.3.1 <2.0.0",
      "lastSync": "2026-04-25",
      "optional": true,
      "requiresNode": ">=20.19.0",
      "mode": "optional-cli-adapter",
      "notes": "OpenSpec is used as an optional artifact protocol and CLI validation/archive adapter for v1. OpenSpec skills are not installed by this extension. AI Factory-only mode remains supported without the OpenSpec CLI."
    }
  },
  "skills": [
    "skills/aif-analyze",
    "skills/aif-done",
    "skills/aif-rules-check"
  ],
  "agentFiles": [
    {
      "runtime": "codex",
      "source": "./agent-files/codex/aifhub-plan-polisher.toml",
      "target": "aifhub-plan-polisher.toml"
    },
    {
      "runtime": "codex",
      "source": "./agent-files/codex/aifhub-implement-worker.toml",
      "target": "aifhub-implement-worker.toml"
    },
    {
      "runtime": "codex",
      "source": "./agent-files/codex/aifhub-review-sidecar.toml",
      "target": "aifhub-review-sidecar.toml"
    },
    {
      "runtime": "codex",
      "source": "./agent-files/codex/aifhub-security-sidecar.toml",
      "target": "aifhub-security-sidecar.toml"
    },
    {
      "runtime": "codex",
      "source": "./agent-files/codex/aifhub-verifier.toml",
      "target": "aifhub-verifier.toml"
    },
    {
      "runtime": "codex",
      "source": "./agent-files/codex/aifhub-fixer.toml",
      "target": "aifhub-fixer.toml"
    },
    {
      "runtime": "codex",
      "source": "./agent-files/codex/aifhub-rules-sidecar.toml",
      "target": "aifhub-rules-sidecar.toml"
    },
    {
      "runtime": "codex",
      "source": "./agent-files/codex/aifhub-done-finalizer.toml",
      "target": "aifhub-done-finalizer.toml"
    },
    {
      "runtime": "claude",
      "source": "./agent-files/claude/aifhub-plan-polisher.md",
      "target": "aifhub-plan-polisher.md"
    },
    {
      "runtime": "claude",
      "source": "./agent-files/claude/aifhub-implement-worker.md",
      "target": "aifhub-implement-worker.md"
    },
    {
      "runtime": "claude",
      "source": "./agent-files/claude/aifhub-verifier.md",
      "target": "aifhub-verifier.md"
    },
    {
      "runtime": "claude",
      "source": "./agent-files/claude/aifhub-fixer.md",
      "target": "aifhub-fixer.md"
    },
    {
      "runtime": "claude",
      "source": "./agent-files/claude/aifhub-review-sidecar.md",
      "target": "aifhub-review-sidecar.md"
    },
    {
      "runtime": "claude",
      "source": "./agent-files/claude/aifhub-security-sidecar.md",
      "target": "aifhub-security-sidecar.md"
    },
    {
      "runtime": "claude",
      "source": "./agent-files/claude/aifhub-rules-sidecar.md",
      "target": "aifhub-rules-sidecar.md"
    },
    {
      "runtime": "claude",
      "source": "./agent-files/claude/aifhub-done-finalizer.md",
      "target": "aifhub-done-finalizer.md"
    }
  ],
  "injections": [
    {
      "target": "aif-plan",
      "position": "prepend",
      "file": "./injections/core/aif-plan-plan-folder.md"
    },
    {
      "target": "aif-explore",
      "position": "prepend",
      "file": "./injections/core/aif-explore-plan-folder.md"
    },
    {
      "target": "aif-roadmap",
      "position": "prepend",
      "file": "./injections/core/aif-roadmap-maturity-audit.md"
    },
    {
      "target": "aif-fix",
      "position": "prepend",
      "file": "./injections/core/aif-fix-plan-folder.md"
    },
    {
      "target": "aif-verify",
      "position": "prepend",
      "file": "./injections/core/aif-verify-plan-folder.md"
    },
    {
      "target": "aif-improve",
      "position": "prepend",
      "file": "./injections/core/aif-improve-plan-folder.md"
    },
    {
      "target": "aif-implement",
      "position": "prepend",
      "file": "./injections/core/aif-implement-plan-folder.md"
    },
    {
      "target": "aif-evolve",
      "position": "prepend",
      "file": "./injections/core/aif-evolve-plan-evidence.md"
    }
  ]
}
